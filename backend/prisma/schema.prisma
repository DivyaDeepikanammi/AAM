generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MOM
  ADMIN
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
}

enum Status {
  PENDING
  DONE
  MISSED
  TAKEN
}

enum ReminderType {
  BREAKFAST
  LUNCH
  DINNER
  MORNING_TABLET
  AFTERNOON_TABLET
  NIGHT_TABLET
  WALKING
  WATER
  MONTHLY_SUGAR_CHECK
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  refreshHash  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mealLogs            MealLog[]
  medicineLogs        MedicineLog[]
  notifications       Notification[]
  painLogs            PainLog[]
  monthlyHealthChecks MonthlyHealthCheck[]

  @@map("users")
}

model Meal {
  id             String   @id @default(cuid())
  date           DateTime
  type           MealType
  menuItem       String
  curryName      String?
  portion        String
  alternative    String?
  recipeId       String?
  recipe         Recipe?  @relation(fields: [recipeId], references: [id])
  createdAt      DateTime @default(now())
  logs           MealLog[]

  @@map("meals")
}

model MealLog {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  mealId      String
  meal        Meal      @relation(fields: [mealId], references: [id])
  status      Status    @default(PENDING)
  completedAt DateTime?

  @@map("meal_logs")
}

model WeeklyMealPlan {
  id               String   @id @default(cuid())
  day              String
  breakfast        String
  lunch            String
  dinner           String
  curry            String
  alternativeCurry String
  createdAt        DateTime @default(now())

  @@map("weekly_meal_plans")
}

model Recipe {
  id           String   @id @default(cuid())
  name         String
  vegetable    String
  type         String
  ingredients  String
  steps        Json
  oilSuggestion String
  saltCaution  String
  diabetesNote String
  servingSize  String
  lastUsedAt   DateTime?
  createdAt    DateTime @default(now())
  meals        Meal[]

  @@map("recipes")
}

model Medicine {
  id        String   @id @default(cuid())
  name      String
  dosage    String
  time      String
  foodRule  String
  active    Boolean  @default(true)
  logs      MedicineLog[]

  @@map("medicines")
}

model MedicineLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  medicineId  String
  medicine    Medicine @relation(fields: [medicineId], references: [id])
  status      Status   @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@map("medicine_logs")
}

model Reminder {
  id        String       @id @default(cuid())
  type      ReminderType
  title     String
  time      String
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now())

  @@map("reminders")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model PainLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  level     Int
  notes     String?
  createdAt DateTime @default(now())

  @@map("pain_logs")
}

model MonthlyHealthCheck {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  month         DateTime
  fastingSugar  Int?
  ppSugar       Int?
  hba1c         Float?
  bp            String?
  weight        Float?
  notes         String?
  createdAt     DateTime @default(now())

  @@map("monthly_health_checks")
}

model Stat {
  id        String   @id @default(cuid())
  date      DateTime
  dailyCompletion Int
  weeklyCompletion Int
  mealsCompleted Int
  tabletsCompleted Int
  missedTablets Int
  missedMeals Int
  waterCompletion Int
  walkingCompletion Int
  painTrend Json
  createdAt DateTime @default(now())

  @@map("stats")
}
